{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    },
    "api/send-mail.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },

  "routes": [
    {
      "src": "/",
      "dest": "/api/index.php"
    },
    {
      "src": "/send-mail.php",
      "dest": "/api/send-mail.php"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    }
  ]
}